class Solution {
    public int maxSubarraySum(int[] arr, int k) {
        int s = 0;
        int ms = 0;
        for(int i = 0; i < k ; i++){
            s += arr[i];
        }
        ms = s;
        for(int i = k ; i < arr.length; i++){
            s = s + arr[i] - arr[i - k];
            ms = Math.max(s , ms);
        }
        return ms;
    }
}
